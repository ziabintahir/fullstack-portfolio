# ─── Server ──────────────────────────────────────
NODE_ENV=development
PORT=5000

# ─── Database ────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=portfolio_user
DB_PASSWORD=your_strong_password_here
DB_NAME=portfolio_db

# ─── JWT ─────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_64_char_random_hex_string
JWT_EXPIRES_IN=7d

# ─── CORS ────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,https://ziaai.vercel.app

# ─── Email (Nodemailer) ───────────────────────────
EMAIL_SERVICE=gmail
EMAIL_USER=your@gmail.com
EMAIL_PASS=your_gmail_app_password   # https://myaccount.google.com/apppasswords
EMAIL_TO=your@gmail.com

# ─── Logging ─────────────────────────────────────
LOG_LEVEL=info

# ─── Swagger ─────────────────────────────────────
ENABLE_SWAGGER=true
